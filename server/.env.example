# Copy this file to .env and fill in your own values

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/loomwatch

# Secret used to sign JWTs - use a long random string
JWT_SECRET=change_this_to_something_long_and_random

# Server port
PORT=5000

# Optional: real LLM integration for agent reasoning.
# If left blank, Loomwatch falls back to a deterministic
# local "personality engine" so the app still runs and demos
# fully without any API key.
ANTHROPIC_API_KEY=
